@using Olimpiadnic.Models
@model AdminStatisticsViewModel

@{
    ViewData["Title"] = "Статистика";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="~/css/StatisticStyles.css" />
</head>
<body>

<h2 class="mb-4">
    <i class="fas fa-chart-line me-2"></i>Статистика
    <small class="text-muted fs-6">Общая информация о платформе</small>
</h2>

<!-- Карточки статистики -->
<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-number">@Model.TotalUsers</div>
            <div class="stat-label">Всего пользователей</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-number">@Model.TotalOlympiads</div>
            <div class="stat-label">Всего олимпиад</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-number">@Model.TotalParticipations</div>
            <div class="stat-label">Всего участий</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-number">@Model.ActiveOlympiads</div>
            <div class="stat-label">Активных олимпиад</div>
        </div>
    </div>
</div>

<!-- Таблица статистики по олимпиадам -->
<h4 class="mb-3">
    <i class="fas fa-chart-bar me-2"></i>Статистика по олимпиадам
</h4>

<div class="table-responsive stat-table">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>ID</th>
                <th>Название олимпиады</th>
                <th>Участников</th>
                <th>Завершили</th>
                <th>Статус</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var olympiad in Model.OlympiadStats)
            {
                <tr>
                    <td>@olympiad.OlympiadId</td>
                    <td>@olympiad.Title</td>
                    <td>@olympiad.ParticipantsCount</td>
                    <td>@olympiad.CompletedCount</td>
                    <td>
                        @if (olympiad.Status == "Активна")
                        {
                            <span class="badge bg-success">@olympiad.Status</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@olympiad.Status</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

</body>
</html>