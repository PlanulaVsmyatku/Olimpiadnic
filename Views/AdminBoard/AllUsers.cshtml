@using Olimpiadnic.Models
@model List<UserAdminViewModel>

@{
    ViewData["Title"] = "Управление пользователями";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="~/css/AllUsersStyle.css" />
</head>
<body>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>
        <i class="fas fa-users me-2"></i>Управление пользователями
        <small class="text-muted fs-6">Список всех зарегистрированных пользователей</small>
    </h2>
    <a href="/Dashboard/CreateUser" class="btn btn-primary btn-add-user">
        <i class="fas fa-user-plus me-2"></i>Добавить пользователя
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>ID</th>
                <th>Логин</th>
                <th>ФИО</th>
                <th>Email</th>
                <th>Роль</th>
                <th>Статус</th>
                <th>Дата регистрации</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.UserId</td>
                    <td>@user.Login</td>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td>
                        @if (user.Role == "Администратор")
                        {
                            <span class="badge bg-danger">@user.Role</span>
                        }
                        else if (user.Role == "Сотрудник")
                        {
                            <span class="badge bg-primary">@user.Role</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@user.Role</span>
                        }
                    </td>
                    <td>
                        <span class="user-status @(user.IsActive ? "status-active" : "status-inactive")">
                            @(user.IsActive ? "Активен" : "Неактивен")
                        </span>
                    </td>
                    <td>@user.RegisteredAt.ToString("dd.MM.yyyy")</td>
                    <td>
                        <div class="dropdown action-dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                <i class="fas fa-cog"></i>
                            </button>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" href="/Dashboard/EditUser/@user.UserId">
                                        <i class="fas fa-edit"></i> Редактировать
                                    </a>
                                </li>
                                <li>
                                    <form asp-action="DeleteUser" asp-route-id="@user.UserId" method="post" onsubmit="return confirm('Вы уверены, что хотите удалить этого пользователя?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="fas fa-trash-alt"></i> Удалить
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

</body>
</html>