@using Olimpiadnic.Models.OlympiadModels
@model List<OlympiadCardViewModel>

@{
    ViewData["Title"] = "Все олимпиады";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <style>
        .olympiad-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border: none;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.08);
            height: 100%;
        }
        
        .olympiad-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }
        
        .card-img-top {
            height: 200px;
            object-fit: cover;
        }
        
        .badge-status {
            position: absolute;
            top: 15px;
            right: 15px;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            z-index: 1;
        }
        
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            background: white;
            border-radius: 15px;
        }
    </style>
</head>
<body>

<h2 class="mb-4">
    <i class="fas fa-globe me-2"></i>Все олимпиады
    <small class="text-muted fs-6">Полный список всех олимпиад на платформе</small>
</h2>

@if (Model.Any())
{
    <div class="row g-4">
        @foreach (var olympiad in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card olympiad-card">
                    <div class="position-relative">
                        <img src="@olympiad.ImageUrl" class="card-img-top" alt="@olympiad.Title" loading="lazy">
                        <span class="badge-status" style="background: @GetStatusColor(olympiad.Status); color: white;">
                            @olympiad.Status
                        </span>
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">@olympiad.Title</h5>
                        <p class="card-text">@(olympiad.Description.Length > 100 ? olympiad.Description.Substring(0, 100) + "..." : olympiad.Description)</p>
                        <div class="date-info">
                            <i class="fas fa-calendar-alt"></i>
                            <strong>Начало:</strong> @olympiad.EventStart.ToString("dd.MM.yyyy")
                        </div>
                        <div class="date-info mb-3">
                            <i class="fas fa-calendar-check"></i>
                            <strong>Конец:</strong> @olympiad.EventEnd.ToString("dd.MM.yyyy")
                        </div>
                        <div class="d-grid">
                            <a href="/Olympiad/Details/@olympiad.OlympiadId" class="btn btn-primary">
                                <i class="fas fa-eye me-2"></i>Подробнее
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state">
        <i class="fas fa-info-circle fa-3x text-muted mb-3"></i>
        <h4>Олимпиады не найдены</h4>
        <p class="text-muted">На данный момент нет доступных олимпиад</p>
    </div>
}

@functions {
    public string GetStatusColor(string status)
    {
        return status switch
        {
            "Регистрация открыта" => "#10b981",
            "Идёт" => "#3b82f6",
            "Завершена" => "#ef4444",
            "Регистрация скоро" => "#f59e0b",
            _ => "#6b7280"
        };
    }
}

</body>
</html>