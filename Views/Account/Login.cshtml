@using Olimpiadnic.Models.AccountModels
@model LoginViewModel

@{
    ViewData["Title"] = "Вход";
    var returnUrl = ViewData["ReturnUrl"] as string;
}
<head>
    <link rel="stylesheet" href="~/css/ImgWord.css" />
</head>

<body style="background-color: #f0f0f0;">

    <main class="container mt-5" aria-labelledby="login-heading">
        <section class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
            
                <article class="card shadow border-0 rounded-4">
                    <div class="card-body p-4 p-md-5">
                    
                        <header class="text-center mb-4">
                            <h1 id="login-heading" class="h2">Вход в аккаунт</h1>
                            <p class="text-muted">Добро пожаловать</p>
                        </header>
                    
                        <form asp-action="Login"
                              asp-route-returnUrl="@returnUrl"
                              method="post"
                              novalidate>
                        
                            <!-- Общие ошибки аутентификации -->
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        
                            <!-- Логин или Email -->
                            <div class="mb-3">
                                <label asp-for="LoginOrEmail" class="form-label fw-semibold"></label>
                                <input asp-for="LoginOrEmail"
                                       class="form-control"
                                       placeholder="ivanov@example.com или Ivanov"
                                       autocomplete="username"
                                       autofocus>
                                <span asp-validation-for="LoginOrEmail" class="text-danger"></span>
                            </div>
                        
                            <!-- Пароль -->
                            <div class="mb-3">
                                <label asp-for="Password" class="form-label fw-semibold"></label>
                                <input asp-for="Password"
                                       class="form-control"
                                       type="password"
                                       placeholder="Введите пароль"
                                       autocomplete="current-password">
                            
                                <!-- Чекбокс показа пароля -->
                                <div class="form-check mt-2">
                                    <input class="form-check-input" type="checkbox" id="showPassword">
                                    <label class="form-check-label" for="showPassword">
                                        Показать пароль
                                    </label>
                                </div>
                            
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>
                        
                            <!-- Запомнить меня и ссылка на восстановление -->
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" asp-for="RememberMe">
                                    <label class="form-check-label" asp-for="RememberMe"></label>
                                </div>
                                <a asp-controller="PasswordRecovery" asp-action="ForgotPassword" class="text-decoration-none small">
                                    Забыли пароль?
                                </a>
                            </div>
                        
                            <!-- Кнопка входа -->
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    Войти
                                </button>
                            </div>
                        
                            <!-- Регистрация -->
                            <footer class="text-center mt-4">
                                <p class="mb-0 small">
                                    Нет аккаунта?
                                    <a asp-action="Register" class="text-decoration-none fw-semibold">
                                        Зарегистрироваться
                                    </a>
                                </p>
                            </footer>
                        
                        </form>
                    </div>
                </article>
            
            </div>
        </section>
    </main>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    
        <script>
                // Показ/скрытие пароля
                const showPasswordCheckbox = document.getElementById('showPassword');
                const passwordInput = document.getElementById('Password');
        
                if (showPasswordCheckbox && passwordInput) {
                    showPasswordCheckbox.addEventListener('change', function() {
                        passwordInput.type = this.checked ? 'text' : 'password';
                    });
                }
        </script>
    }

</body>
