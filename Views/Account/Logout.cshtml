@{
    ViewData["Title"] = "Выход из системы";
    var redirectUrl = Url.Action("Index", "Home");
    var redirectSeconds = 5;
}

<main class="container mt-5">
    <section class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            
            <!-- Анимированная карточка выхода -->
            <article class="card shadow-lg border-0 rounded-4 overflow-hidden">
                
                <!-- Цветная полоса сверху -->
                <div class="bg-danger" style="height: 6px;"></div>
                
                <div class="card-body p-4 p-md-5 text-center">
                    
                    <!-- Анимированная иконка -->
                    <div class="mb-4">
                        <div class="bg-light rounded-circle d-inline-flex p-3" style="animation: pulse 2s infinite;">
                            <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" stroke="#dc3545" stroke-linecap="round" />
                                <polyline points="16 17 21 12 16 7" stroke="#dc3545" stroke-linecap="round" />
                                <line x1="9" y1="12" x2="21" y2="12" stroke="#dc3545" stroke-linecap="round" />
                            </svg>
                        </div>
                    </div>
                    
                    <h1 class="h2 mb-2">Выход выполнен</h1>
                    <p class="text-muted mb-4">
                        Ваша сессия завершена. Все сохранённые данные защищены.
                    </p>
                    
                    <!-- Анимированный таймер -->
                    <div class="position-relative mb-4" style="width: 120px; height: 120px; margin: 0 auto;">
                        <svg viewBox="0 0 100 100" style="transform: rotate(-90deg);">
                            <circle cx="50" cy="50" r="45" fill="none" stroke="#e9ecef" stroke-width="8" />
                            <circle id="timerCircle"
                                    cx="50" cy="50" r="45"
                                    fill="none"
                                    stroke="#0d6efd"
                                    stroke-width="8"
                                    stroke-dasharray="282.6"
                                    stroke-dashoffset="0"
                                    stroke-linecap="round" />
                        </svg>
                        <div class="position-absolute top-50 start-50 translate-middle">
                            <span id="timerNumber" class="display-4 fw-bold text-primary">5</span>
                        </div>
                    </div>
                    
                    <p class="text-muted small mb-4">
                        Перенаправление на главную через <span id="timerText">5</span> секунд
                    </p>
                    
                    <div class="d-flex gap-3 justify-content-center">
                        <button id="cancelRedirect" class="btn btn-outline-secondary">
                            Остаться на странице
                        </button>
                        <a href="@redirectUrl" class="btn btn-primary" id="redirectNow">
                            Перейти сейчас
                        </a>
                    </div>
                    
                    <hr class="my-4">
                    
                    <p class="small text-muted mb-0">
                        Не вы выходили из системы?
                        <a asp-controller="Account" asp-action="Login" class="text-decoration-none">
                            Войти снова
                        </a>
                    </p>
                    
                </div>
            </article>
            
        </div>
    </section>
</main>

<style>
    @@keyframes pulse {
        0% {
            transform: scale(1);
            opacity: 1;
        }
        50% {
            transform: scale(1.05);
            opacity: 0.8;
        }
        100% {
            transform: scale(1);
            opacity: 1;
        }
    }
</style>

@section Scripts {
    <script>
        let secondsLeft = @redirectSeconds;
        let redirectCancelled = false;
        
        const timerNumber = document.getElementById('timerNumber');
        const timerText = document.getElementById('timerText');
        const timerCircle = document.getElementById('timerCircle');
        const cancelBtn = document.getElementById('cancelRedirect');
        const redirectUrl = '@redirectUrl';
        
        const circumference = 2 * Math.PI * 45; // ~282.6
        
        function updateTimer() {
            if (redirectCancelled) return;
            
            secondsLeft--;
            
            if (secondsLeft <= 0) {
                window.location.href = redirectUrl;
                return;
            }
            
            timerNumber.textContent = secondsLeft;
            timerText.textContent = secondsLeft;
            
            // Анимация круга
            const offset = circumference - (secondsLeft / @redirectSeconds) * circumference;
            timerCircle.style.strokeDashoffset = offset;
        }
        
        // Отмена автоматического перенаправления
        cancelBtn.addEventListener('click', function() {
            redirectCancelled = true;
            cancelBtn.disabled = true;
            cancelBtn.textContent = 'Перенаправление отменено';
            document.getElementById('redirectNow').classList.add('btn-success');
            document.getElementById('redirectNow').classList.remove('btn-primary');
            timerNumber.style.opacity = '0.5';
            timerCircle.style.stroke = '#6c757d';
            timerText.textContent = 'отменено';
        });
        
        // Запуск таймера
        let timerInterval = setInterval(updateTimer, 1000);
        
        // Очистка при уходе со страницы
        window.addEventListener('beforeunload', function() {
            clearInterval(timerInterval);
        });
    </script>
}
