@using Olimpiadnic.Models.HomeModels
@model IndexViewModel

@{
    ViewData["Title"] = "Главная страница";
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
}
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Олимпиады Онлайн</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Кастомный стиль для страницы -->
    <link rel="stylesheet" href="~/css/HomePageStyles.css" />
</head>

<body style="background-color: #f0f0f0;">
    <!-- Header -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">
                <a class="navbar-brand" href="/">
                    <i class="fas fa-trophy me-2"></i>
                    Олимпиады Онлайн
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link active" href="/">Главная</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Все олимпиады</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Мои олимпиады</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">
                                <i class="fas fa-user"></i> Войти
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main>
        <!-- Добро пожаловать -->
        <section class="hero-section text-center">
            <div class="container">
                <h1 class="display-4 fw-bold">
                    <i class="fas fa-trophy me-2"></i>
                    Добро пожаловать в Олимпиадник
                </h1>
                <p class="lead">Проверьте свои знания, соревнуйтесь с лучшими и достигайте новых высот</p>
                @if (!isAuthenticated)
                {
                    <div class="mt-4">
                        <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg me-3">
                            <i class="fas fa-user-plus me-2"></i>Зарегестрироваться сейчас
                        </a>
                        <a href="#olympiads" class="btn btn-outline-light btn-lg">
                            <i class="fas fa-search me-2"></i>Смотреть олимпиады
                        </a>
                    </div>
                }
            </div>
        </section>

        <div class="container">
            <!-- Секция поиска -->
            <section class="search-card" aria-label="Поиск олимпиад">
                <h3 class="mb-4">
                    <i class="fas fa-search me-2" style="color: #667eea;"></i>
                    Поиск олимпиад
                </h3>

                <form method="get" asp-action="Index" asp-controller="Home" novalidate>
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="SearchModel!.SearchTitle" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0">
                                    <i class="fas fa-tag text-muted"></i>
                                </span>
                                <input asp-for="SearchModel!.SearchTitle"
                                       class="form-control border-start-0"
                                       placeholder="Например: математика">
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="SearchModel!.StartDateFrom" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-white">
                                    <i class="fas fa-calendar-alt"></i>
                                </span>
                                <input asp-for="SearchModel!.StartDateFrom"
                                       class="form-control"
                                       type="date">
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="SearchModel!.StartDateTo" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-white">
                                    <i class="fas fa-calendar-check"></i>
                                </span>
                                <input asp-for="SearchModel!.StartDateTo"
                                       class="form-control"
                                       type="date">
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="SearchModel!.EndDateFrom" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-white">
                                    <i class="fas fa-calendar-alt"></i>
                                </span>
                                <input asp-for="SearchModel!.EndDateFrom"
                                       class="form-control"
                                       type="date">
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="SearchModel!.EndDateTo" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-white">
                                    <i class="fas fa-calendar-check"></i>
                                </span>
                                <input asp-for="SearchModel!.EndDateTo"
                                       class="form-control"
                                       type="date">
                            </div>
                        </div>

                        <div class="col-12">
                            <hr />
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary px-4">
                                    <i class="fas fa-search me-2"></i>Найти
                                </button>
                                <a asp-action="Index" class="btn btn-secondary px-4">
                                    <i class="fas fa-undo-alt me-2"></i>Сбросить
                                </a>
                                @if (Model.HasResults)
                                {
                                    <span class="ms-auto text-muted">
                                        <i class="fas fa-chart-line me-1"></i>
                                        Найдено: @Model.TotalCount
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </form>
            </section>

            <!-- Массив карточке олимпиад -->
            <section id="olympiads" aria-label="Список олимпиад">
                @if (Model.HasResults)
                {
                    <div class="row g-4">
                        @foreach (var olympiad in Model.Olympiads)
                        {
                            <div class="col-md-6 col-lg-4">
                                <article class="card olympiad-card">
                                    <div class="position-relative">
                                        @if (!string.IsNullOrEmpty(olympiad.ImageUrl))
                                        {
                                            <img src="@olympiad.ImageUrl"
                                                 class="card-img-top"
                                                 alt="@olympiad.Title"
                                                 loading="lazy">
                                        }
                                        else
                                        {
                                            <img src="/images/default-olympiad.jpg"
                                                 class="card-img-top"
                                                 alt="Изображение олимпиады"
                                                 loading="lazy">
                                        }
                                        <span class="badge-status" style="background: @GetStatusColor(olympiad.Status); color: white;">
                                            @olympiad.Status
                                        </span>
                                    </div>

                                    <div class="card-body d-flex flex-column">
                                        <h5 class="card-title">@olympiad.Title</h5>
                                        <p class="card-text">
                                            @(olympiad.Description.Length > 120 ?
                                                olympiad.Description.Substring(0, 120) + "..." :
                                                olympiad.Description)
                                        </p>

                                        <div class="mt-auto">
                                            <div class="date-info">
                                                <i class="fas fa-calendar-alt"></i>
                                                <strong>Начало:</strong> @olympiad.EventStart.ToString("dd.MM.yyyy HH:mm")
                                            </div>
                                            <div class="date-info mb-3">
                                                <i class="fas fa-calendar-check"></i>
                                                <strong>Конец:</strong> @olympiad.EventEnd.ToString("dd.MM.yyyy HH:mm")
                                            </div>

                                            <div class="d-grid gap-2">
                                                @{
                                                    var now = DateTime.Now;
                                                    if (now >= olympiad.RegistOpen && now <= olympiad.RegistClosed)
                                                    {
                                                        if (isAuthenticated)
                                                        {
                                                            <button class="btn-register"
                                                                    onclick="location.href='/Olympiad/Register/@olympiad.OlympiadId'">
                                                                <i class="fas fa-pen-alt me-2"></i>Записаться
                                                            </button>
                                                        }
                                                        else
                                                        {
                                                            <button class="btn-register"
                                                                    onclick="location.href='/Account/Login?returnUrl=/Olympiad/Register/@olympiad.OlympiadId'">
                                                                <i class="fas fa-sign-in-alt me-2"></i>Войдите для записи
                                                            </button>
                                                        }
                                                    }
                                                    else if (now < olympiad.RegistOpen)
                                                    {
                                                        <button class="btn-outline-register" disabled>
                                                            <i class="fas fa-clock me-2"></i>
                                                            Регистрация с @olympiad.RegistOpen.ToString("dd.MM")
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn-outline-register" disabled>
                                                            <i class="fas fa-ban me-2"></i>Регистрация закрыта
                                                        </button>
                                                    }
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </article>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fas fa-search"></i>
                        <h3 class="mt-3">Ничего не найдено</h3>
                        <p class="text-muted">Попробуйте изменить параметры поиска или сбросить фильтры</p>
                        <a asp-action="Index" class="btn btn-primary mt-3">
                            <i class="fas fa-undo-alt me-2"></i>Показать все олимпиады
                        </a>
                    </div>
                }
            </section>
        </div>
    </main>
</body>

@functions {
    public string GetStatusColor(string status)
    {
        return status switch
        {
            "Регистрация открыта" => "#10b981",
            "Идёт" => "#3b82f6",
            "Завершена" => "#ef4444",
            "Регистрация скоро" => "#f59e0b",
            _ => "#6b7280"
        };
    }
}
