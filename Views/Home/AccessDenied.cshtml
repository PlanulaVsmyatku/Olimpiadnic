@{
    ViewData["Title"] = "Доступ запрещён";
}

<main class="container mt-5" aria-labelledby="denied-heading">
    <section class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <article class="card shadow border-0 rounded-4 text-center">
                <div class="card-body p-4 p-md-5">
                    <header class="mb-4">
                        <figure class="mb-3">
                            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <circle cx="12" cy="12" r="10" stroke="#dc3545" />
                                <line x1="18" y1="6" x2="6" y2="18" stroke="#dc3545" stroke-linecap="round" />
                            </svg>
                        </figure>
                        <h1 id="denied-heading" class="h2 text-danger">Доступ запрещён</h1>
                        <p class="text-muted mt-2">У вас недостаточно прав для просмотра этой страницы</p>
                    </header>
                    <footer class="mt-4">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">На главную</a>
                    </footer>
                </div>
            </article>
        </div>
    </section>
</main>