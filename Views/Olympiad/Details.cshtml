@using Olimpiadnic.Models.OlympiadModels
@model OlympiadDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
    var now = DateTime.Now;
    var canRegister = now >= Model.RegistOpen && now <= Model.RegistClosed;
    var isActive = now >= Model.EventStart && now <= Model.EventEnd;
}

<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="~/css/DetailsStyles.css" />
</head>
<body>

    <!-- Hero секция -->
    <div class="olympiad-header">
        <div class="container">
            <h1 class="display-4 fw-bold">@Model.Title</h1>
            <p class="lead">Проверьте свои знания и получите сертификат</p>
        </div>
    </div>

    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <!-- Изображение -->
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="olympiad-image" alt="@Model.Title" />
                }

                <!-- Один белый блок для описания и критериев -->
                <div class="info-card">
                    <h4><i class="fas fa-align-left me-2"></i>Описание олимпиады</h4>
                    <div class="description-content">
                        @Html.Raw(Model.Description)
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Credentials))
                    {
                        <div class="credentials-section">
                            <h5><i class="fas fa-clipboard-list me-2"></i>Критерии допуска</h5>
                            <p class="mb-0">@Model.Credentials</p>
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-4">
                <!-- Информационная карточка -->
                <div class="info-card">
                    <h4><i class="fas fa-info-circle me-2"></i>Информация</h4>

                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-tag me-2"></i>Статус</div>
                        <div class="info-value">
                            <span class="status-badge status-@Model.Status">
                                @(Model.Status == "available" ? "Доступна" :
                                  Model.Status == "in_progress" ? "В процессе" : "Завершена")
                            </span>
                        </div>
                    </div>

                    <!-- Статус прохождения (для авторизованных) -->
                    @if (Context.User.Identity?.IsAuthenticated == true)
                    {
                        <div class="info-item">
                            <div class="info-label"><i class="fas fa-user-check me-2"></i>Ваше участие</div>
                            <div class="info-value">
                                @if (Model.IsCompleted)
                                {
                                    <span class="completion-badge completed">
                                        <i class="fas fa-check-circle me-1"></i>Завершена
                                    </span>
                                    <div class="score-preview">
                                        <div class="score-label">Набранные баллы</div>
                                        <div class="score-value">@(Model.UserTotalScore ?? 0) / @Model.TotalQuestions</div>
                                        <div class="score-label mt-1">
                                            @{
                                                var percentage = Model.TotalQuestions > 0
                                                    ? ((Model.UserTotalScore ?? 0) * 100 / Model.TotalQuestions)
                                                    : 0;
                                            }
                                            @percentage% выполнения
                                        </div>
                                        @if (Model.CompletedAt.HasValue)
                                        {
                                            <div class="score-label mt-1" style="font-size: 0.7rem;">
                                                <i class="fas fa-calendar-alt me-1"></i>@Model.CompletedAt.Value.ToString("dd.MM.yyyy HH:mm")
                                            </div>
                                        }
                                    </div>
                                }
                                else if (Model.IsRegistered)
                                {
                                    <span class="completion-badge not-completed">
                                        <i class="fas fa-hourglass-half me-1"></i>Начато, но не завершено
                                    </span>
                                    <div class="score-preview mt-2">
                                        <i class="fas fa-info-circle me-1"></i>
                                        <span class="score-label">Продолжите прохождение</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="completion-badge not-completed">
                                        <i class="fas fa-clock me-1"></i>Не начато
                                    </span>
                                    <div class="score-preview mt-2">
                                        <i class="fas fa-info-circle me-1"></i>
                                        <span class="score-label">Зарегистрируйтесь, чтобы участвовать</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-calendar-alt me-2"></i>Начало</div>
                        <div class="info-value">@Model.EventStart.ToString("dd.MM.yyyy HH:mm")</div>
                    </div>

                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-calendar-check me-2"></i>Окончание</div>
                        <div class="info-value">@Model.EventEnd.ToString("dd.MM.yyyy HH:mm")</div>
                    </div>

                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-clock me-2"></i>Регистрация</div>
                        <div class="info-value">
                            @Model.RegistOpen.ToString("dd.MM.yyyy") - @Model.RegistClosed.ToString("dd.MM.yyyy")
                        </div>
                    </div>

                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-question-circle me-2"></i>Всего вопросов</div>
                        <div class="info-value">@Model.TotalQuestions</div>
                    </div>
                </div>

                <!-- Кнопка действия -->
                <div class="info-card text-center">
                    @if (Model.IsCompleted)
                    {
                        <!-- Если олимпиада завершена - показываем результаты -->
                        <button class="btn-participate btn-results" onclick="location.href='/Olympiad/Results/@Model.OlympiadId'">
                            <i class="fas fa-chart-line me-2"></i>Посмотреть результаты
                        </button>
                    }
                    else if (Model.IsRegistered)
                    {
                        <!-- Если зарегистрирован, но не завершил - продолжаем участие -->
                        <button class="btn-participate" onclick="location.href='/Olympiad/Participate/@Model.OlympiadId'">
                            <i class="fas fa-play me-2"></i>Продолжить участие
                        </button>
                    }
                    else if (canRegister)
                    {
                        <!-- Если не зарегистрирован и регистрация открыта -->
                        <button class="btn-participate" onclick="registerForOlympiad(@Model.OlympiadId)">
                            <i class="fas fa-pen-alt me-2"></i>Записаться на олимпиаду
                        </button>
                    }
                    else if (now < Model.RegistOpen)
                    {
                        <!-- Регистрация ещё не началась -->
                        <button class="btn-participate" disabled style="opacity: 0.6">
                            <i class="fas fa-clock me-2"></i>Регистрация откроется @Model.RegistOpen.ToString("dd.MM.yyyy")
                        </button>
                    }
                    else
                    {
                        <!-- Регистрация закрыта -->
                        <button class="btn-participate" disabled style="opacity: 0.6">
                            <i class="fas fa-ban me-2"></i>Регистрация закрыта
                        </button>
                    }
                </div>

                <!-- Дополнительный блок для завершённых - сертификат -->
                @if (Model.IsCompleted && (Model.UserTotalScore ?? 0) >= Model.TotalQuestions * 0.7m)
                {
                    <div class="info-card text-center mt-3" style="background: linear-gradient(135deg, #fff9e6, #fff3cd);">
                        <i class="fas fa-certificate" style="font-size: 2rem; color: #ffc107;"></i>
                        <h5 class="mt-2">Поздравляем!</h5>
                        <p class="small">Вы набрали достаточно баллов для получения сертификата.</p>
                        <button class="btn btn-sm btn-outline-warning" onclick="location.href='/Olympiad/DownloadCertificate/@Model.OlympiadId'">
                            <i class="fas fa-download me-1"></i>Скачать сертификат
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!--IAntiforgery - защита-->
    @inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
    @{
        var token = Antiforgery.GetAndStoreTokens(Context).RequestToken;
    }
    <input type="hidden" name="__RequestVerificationToken" value="@token" />

    <script>
            function registerForOlympiad(olympiadId) {
                fetch(`/Olympiad/Register/${olympiadId}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Вы успешно записаны!');
                        location.reload();
                    } else {
                        alert(data.message || 'Ошибка при записи');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Произошла ошибка при записи');
                });
            }
    </script>

</body>
</html>