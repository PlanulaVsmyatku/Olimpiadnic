@using Olimpiadnic.Services
@inject IOlympiadSessionService sessionService
@using Olimpiadnic.Models.OlympiadModels
@model OlympiadParticipationViewModel

@{
    ViewData["Title"] = $"{Model.OlympiadTitle} - Вопрос {Model.CurrentQuestionIndex + 1} из {Model.TotalQuestions}";
}

<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="~/css/ParticipateStyles.css" />
</head>
<body>

<div class="container py-4">
    <!-- Заголовок и прогресс -->
    <div class="progress-container">
        <div class="d-flex justify-content-between mb-2">
            <h5 class="mb-0">@Model.OlympiadTitle</h5>
            <span class="text-muted">Вопрос @(Model.CurrentQuestionIndex + 1) из @Model.TotalQuestions</span>
        </div>
        <div class="progress-bar-custom">
            <div class="progress-fill" style="width: @((Model.CurrentQuestionIndex + 1) * 100 / Model.TotalQuestions)%"></div>
        </div>
    </div>

        <!--Уведомление о черновике-->
        @if (Model != null && Model.CurrentQuestionIndex > 0)
        {
            <div class="alert alert-info">
                <i class="fas fa-save"></i> Ваш прогресс сохранен. Вы остановились на вопросе @(Model.CurrentQuestionIndex + 1).
            </div>
        }
    
    <!-- Карточка вопроса -->
    <div class="question-card">
        <!-- Тип вопроса -->
        <div class="question-type-badge @(Model.CurrentQuestion.Type.StartsWith("auto") ? "type-auto" : "type-manual")">
            <i class="fas @(Model.CurrentQuestion.Type.StartsWith("auto") ? "fa-check-circle" : "fa-pen") me-1"></i>
            @(Model.CurrentQuestion.Type.StartsWith("auto") ? "Тестовое задание" : "Развёрнутый ответ")
        </div>
        
        <!-- Номер вопроса -->
        <div class="question-number">
            <i class="fas fa-question-circle me-2"></i>Вопрос @Model.CurrentQuestion.OrderNumber
        </div>
        
        <!-- Текст вопроса -->
        <div class="question-text">
            @Html.Raw(Model.CurrentQuestion.Description)
        </div>
        
        <!-- Вложения (изображения) -->
        @if (Model.CurrentQuestion.Attachments.Any())
        {
            <div class="attachments">
                @foreach (var attachment in Model.CurrentQuestion.Attachments)
                {
                    <img src="@attachment" class="attachment-img" alt="Вложение к вопросу" />
                }
            </div>
            }
            <form asp-action="SaveAnswer" method="post" id="answerForm">
                @Html.AntiForgeryToken()

                <!-- Основные скрытые поля -->
                <input type="hidden" name="OlympiadId" value="@Model.OlympiadId" />
                <input type="hidden" name="ParticipantId" value="@Model.ParticipantId" />
                <input type="hidden" name="CurrentQuestionIndex" value="@Model.CurrentQuestionIndex" />
                <input type="hidden" name="TotalQuestions" value="@Model.TotalQuestions" />
                <input type="hidden" name="QuestionId" value="@Model.CurrentQuestion.QuestionId" />
                <input type="hidden" name="QuestionType" value="@Model.CurrentQuestion.Type" />

                @if (Model.CurrentQuestion.Type == "auto-radio")
                {
                    <div class="options-container">
                        @for (int i = 0; i < Model.CurrentQuestion.Options.Count; i++)
                        {
                            var option = Model.CurrentQuestion.Options[i];
                            <div class="option">
                                <input type="radio"
                                       name="SelectedOptionIds"
                                       value="@option.OptionId"
                                       id="opt_@option.OptionId"
                                @(option.IsSelected ? "checked" : "") />
                                <label for="opt_@option.OptionId">@option.OptionText</label>
                            </div>
                        }
                    </div>
                }
                else if (Model.CurrentQuestion.Type == "auto-checkbox")
                {
                    <div class="options-container">
                        @for (int i = 0; i < Model.CurrentQuestion.Options.Count; i++)
                        {
                            var option = Model.CurrentQuestion.Options[i];
                            <div class="option">
                                <input type="checkbox"
                                       name="SelectedOptionIds"
                                       value="@option.OptionId"
                                       id="opt_@option.OptionId"
                                @(option.IsSelected ? "checked" : "") />
                                <label for="opt_@option.OptionId">@option.OptionText</label>
                            </div>
                        }
                    </div>
                }
                else if (Model.CurrentQuestion.Type == "manual")
                {
                    <textarea name="ManualAnswer"
                              class="manual-answer"
                              placeholder="Введите ваш ответ здесь...">@Model.CurrentQuestion.ManualAnswer</textarea>
                }

                <!-- Кнопки навигации -->
                <div class="nav-buttons mt-4">
                    @if (Model.CurrentQuestionIndex > 0)
                    {
                        <button type="submit" name="action" value="previous" class="btn btn-outline-secondary btn-nav">
                            <i class="fas fa-arrow-left me-2"></i>Назад
                        </button>
                    }
                    else
                    {
                        <div></div>
                    }

                    @if (Model.CurrentQuestionIndex + 1 < Model.TotalQuestions)
                    {
                        <button type="submit" name="action" value="next" class="btn btn-primary btn-nav">
                            Далее<i class="fas fa-arrow-right ms-2"></i>
                        </button>
                    }
                    else
                    {
                        <button type="submit" name="action" value="submit" class="btn btn-submit btn-nav">
                            <i class="fas fa-check-circle me-2"></i>Завершить олимпиаду
                        </button>
                    }
                </div>
            </form>
            

            <!-- Временная отладка -->
            <div style="background: yellow; padding: 10px; margin: 10px 0;">
                <strong>Debug:</strong>
                QuestionId = @Model.CurrentQuestion.QuestionId,
                Type = "@Model.CurrentQuestion.Type",
                Options count = @Model.CurrentQuestion.Options.Count
                CurrentQuestionIndex = @Model.CurrentQuestionIndex
                participantId = @Model.ParticipantId
                sessionKey = "{@Model.OlympiadId}:{@Model.ParticipantId}"
                sessionExists = @sessionService.SessionExists(Model.OlympiadId,Model.ParticipantId)
            </div>

    </div>
    
    <!-- Таймер (опционально) -->
    <div class="text-center text-light mt-3">
        <small><i class="fas fa-clock me-1 "></i>Убедитесь, что у вас есть стабильное интернет-соединение</small>
    </div>
</div>

    <script>
            // Обработка отправки формы для checkbox
            document.getElementById('answerForm').addEventListener('submit', function(e) {
                // Обработка и для radio, и для checkbox
                var selectedIds = [];

                // Собираем выбранные radio (всего один будет)
                var selectedRadio = document.querySelector('input[type="radio"]:checked');
                if (selectedRadio) {
                    selectedIds.push(selectedRadio.value);
                }

                // Собираем выбранные checkbox
                var selectedCheckboxes = document.querySelectorAll('input[type="checkbox"]:checked');
                selectedCheckboxes.forEach(cb => selectedIds.push(cb.value));

                // Удаляем старые поля
                var oldInputs = form.querySelectorAll('input[name="SelectedOptionIds"]');
                oldInputs.forEach(input => input.remove());

                // Добавляем новые поля (для radio это будет одно поле, для checkbox - несколько)
                selectedIds.forEach(id => {
                    var input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'SelectedOptionIds';
                    input.value = id;
                    form.appendChild(input);
                });
            });
    </script>

</body>
</html>