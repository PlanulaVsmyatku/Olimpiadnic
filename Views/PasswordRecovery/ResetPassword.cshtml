@using Olimpiadnic.Models.PasswordRecoveryModels
@model ResetPasswordViewModel

@{
    ViewData["Title"] = "Сброс пароля";
}

<main class="container mt-5" aria-labelledby="reset-heading">
    <section class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            
            <article class="card shadow border-0 rounded-4">
                <div class="card-body p-4 p-md-5">
                    
                    <header class="text-center mb-4">
                        <figure class="mb-3">
                            <svg width="70" height="70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" role="img">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" stroke="#0d6efd" />
                                <path d="M7 11V7a5 5 0 0 1 10 0v4" stroke="#0d6efd" stroke-linecap="round" />
                                <title>Сброс пароля</title>
                            </svg>
                        </figure>
                        
                        <h1 id="reset-heading" class="h2">Создание нового пароля</h1>
                        <p class="text-muted mt-2">
                            Придумайте новый надёжный пароль
                        </p>
                    </header>
                    
                    <form asp-action="ResetPassword" method="post" novalidate>
                        @Html.AntiForgeryToken()
                        
                        <!-- Скрытые поля -->
                        <input type="hidden" asp-for="Token" />
                        <input type="hidden" asp-for="Email" />
                        
                        <!-- Общие ошибки -->
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        
                        <!-- Новый пароль -->
                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">🔒</span>
                                <input asp-for="NewPassword"
                                       class="form-control"
                                       type="password"
                                       id="newPassword"
                                       placeholder="Введите новый пароль"
                                       autocomplete="new-password">
                            </div>
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                            <div class="form-text">Минимум 6 символов, включая буквы и цифры</div>
                        </div>
                        
                        <!-- Подтверждение пароля -->
                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">✓</span>
                                <input asp-for="ConfirmPassword"
                                       class="form-control"
                                       type="password"
                                       id="confirmPassword"
                                       placeholder="Повторите пароль"
                                       autocomplete="new-password">
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                        
                        <!-- Чекбокс показа пароля -->
                        <div class="mb-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="showPasswords">
                                <label class="form-check-label" for="showPasswords">
                                    Показать пароли
                                </label>
                            </div>
                        </div>
                        
                        <!-- Кнопка сброса -->
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                Сбросить пароль
                            </button>
                        </div>
                        
                    </form>
                    
                </div>
            </article>
            
        </div>
    </section>
</main>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    <script>
        // Показ/скрытие паролей
        const showPasswordsCheckbox = document.getElementById('showPasswords');
        const newPasswordInput = document.getElementById('newPassword');
        const confirmPasswordInput = document.getElementById('confirmPassword');
        
        if (showPasswordsCheckbox) {
            showPasswordsCheckbox.addEventListener('change', function() {
                const type = this.checked ? 'text' : 'password';
                newPasswordInput.type = type;
                confirmPasswordInput.type = type;
            });
        }
    </script>
}
