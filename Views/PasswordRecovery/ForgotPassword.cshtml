@using Olimpiadnic.Models.PasswordRecoveryModels
@model ForgotPasswordViewModel

@{
    ViewData["Title"] = "Восстановление пароля";
}

<main class="container mt-5" aria-labelledby="forgot-heading">
    <section class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            
            <article class="card shadow border-0 rounded-4">
                <div class="card-body p-4 p-md-5">
                    
                    <header class="text-center mb-4">
                        <!-- Иконка forgot -->
                        <figure class="mb-3">
                            <svg width="70" height="70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" role="img" aria-label="Восстановление пароля">
                                <circle cx="12" cy="12" r="10" stroke="#0d6efd" />
                                <path d="M12 8v4M12 16h.01" stroke="#0d6efd" stroke-linecap="round" />
                                <title>Восстановление пароля</title>
                            </svg>
                        </figure>
                        
                        <h1 id="forgot-heading" class="h2">Забыли пароль?</h1>
                        <p class="text-muted mt-2">
                            Введите email, указанный при регистрации.<br>
                            Мы отправим инструкции для сброса пароля.
                        </p>
                    </header>
                    
                    <form asp-action="ForgotPassword" method="post" novalidate>
                        @Html.AntiForgeryToken()
                        
                        <!-- Общие ошибки -->
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        
                        <!-- Email -->
                        <div class="mb-4">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">📧</span>
                                <input asp-for="Email"
                                       class="form-control"
                                       placeholder="your@email.com"
                                       autocomplete="email"
                                       autofocus>
                            </div>
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        
                        <!-- Кнопка отправки -->
                        <div class="d-grid gap-2 mb-3">
                            <button type="submit" class="btn btn-primary btn-lg">
                                Отправить инструкции
                            </button>
                        </div>
                        
                        <!-- Ссылка на вход -->
                        <footer class="text-center">
                            <a asp-controller="Account" asp-action="Login" class="text-decoration-none">
                                ← Вернуться ко входу
                            </a>
                        </footer>
                        
                    </form>
                    
                </div>
            </article>
            
        </div>
    </section>
</main>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
