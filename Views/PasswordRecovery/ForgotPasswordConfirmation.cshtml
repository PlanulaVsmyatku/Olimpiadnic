@{
    ViewData["Title"] = "Инструкция отправлена";
}

<main class="container mt-5" aria-labelledby="confirmation-heading">
    <section class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            
            <article class="card shadow border-0 rounded-4 text-center">
                <div class="card-body p-4 p-md-5">
                    
                    <header class="mb-4">
                        <!-- Иконка успеха -->
                        <figure class="mb-3">
                            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" role="img" aria-label="Успешно">
                                <circle cx="12" cy="12" r="10" stroke="#198754" />
                                <path d="M8 12L11 15L16 9" stroke="#198754" stroke-linecap="round" />
                                <title>Успешно</title>
                            </svg>
                        </figure>
                        
                        <h1 id="confirmation-heading" class="h3 text-success">
                            Проверьте вашу почту
                        </h1>
                    </header>
                    
                    <section class="my-4">
                        <div class="alert alert-success" role="alert">
                            <p class="mb-0">
                                Мы отправили инструкции по сбросу пароля на ваш email.
                            </p>
                        </div>
                        
                        <div class="mt-4 p-3 bg-light rounded">
                            <p class="small text-muted mb-0">
                                <strong>📬 Что делать дальше?</strong><br>
                                1. Откройте письмо от нас<br>
                                2. Перейдите по ссылке для сброса пароля<br>
                                3. Создайте новый пароль<br>
                                4. Войдите в систему с новым паролем
                            </p>
                        </div>
                    </section>
                    
                    <footer class="mt-4">
                        <div class="d-flex flex-column gap-2">
                            <a asp-action="Login" class="btn btn-primary">
                                Перейти ко входу
                            </a>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                                На главную
                            </a>
                        </div>
                        
                        <p class="mt-3 small text-muted">
                            Не получили письмо?
                            <a asp-action="ForgotPassword" class="text-decoration-none">
                                Отправить снова
                            </a>
                        </p>
                    </footer>
                    
                </div>
            </article>
            
            @if (TempData["DebugResetLink"] != null)
            {
                <!-- Только для разработки: ссылка для тестирования -->
                <div class="alert alert-warning mt-3" role="alert">
                    <strong>🔧 Режим разработки:</strong><br>
                    <small>
                        Ссылка для сброса:
                        <a href="@TempData["DebugResetLink"]" target="_blank">
                            @TempData["DebugResetLink"]
                        </a>
                    </small>
                </div>
            }
            
        </div>
    </section>
</main>
