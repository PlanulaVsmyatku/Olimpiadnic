@{
    ViewData["Title"] = "Пароль успешно изменён";
}

<main class="container mt-5" aria-labelledby="success-heading">
    <section class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            
            <article class="card shadow border-0 rounded-4 text-center">
                <div class="card-body p-4 p-md-5">
                    
                    <header class="mb-4">
                        <figure class="mb-3">
                            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" role="img">
                                <circle cx="12" cy="12" r="10" stroke="#198754" />
                                <path d="M8 12L11 15L16 9" stroke="#198754" stroke-linecap="round" />
                                <title>Успешно</title>
                            </svg>
                        </figure>
                        
                        <h1 id="success-heading" class="h2 text-success">
                            Пароль успешно изменён!
                        </h1>
                    </header>
                    
                    <section class="my-4">
                        <div class="alert alert-success" role="alert">
                            <p class="mb-0">
                                Ваш пароль был успешно обновлён. Теперь вы можете войти в систему, используя новый пароль.
                            </p>
                        </div>
                    </section>
                    
                    <footer class="mt-4">
                        <div class="d-flex gap-3 justify-content-center">
                            <a asp-action="Login" class="btn btn-primary btn-lg px-4">
                                Войти в аккаунт
                            </a>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                                На главную
                            </a>
                        </div>
                    </footer>
                    
                </div>
            </article>
            
        </div>
    </section>
</main>
